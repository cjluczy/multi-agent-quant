<!doctype html>
<html lang="zh-CN">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>多智能体量化控制台</title>
  <style>
    :root {
      --bg: #08111f;
      --panel: rgba(12, 24, 43, 0.88);
      --panel-soft: rgba(11, 20, 37, 0.78);
      --line: rgba(143, 180, 235, 0.14);
      --text: #eff6ff;
      --muted: #94a3b8;
      --accent: #67e8f9;
      --accent-2: #5eead4;
      --good: #4ade80;
      --bad: #fb7185;
      --warn: #fbbf24;
      --radius: 20px;
      --shadow: 0 24px 48px rgba(0, 0, 0, 0.28);
      color-scheme: dark;
    }

    * { box-sizing: border-box; }
    html, body { margin: 0; min-height: 100%; }
    body {
      font-family: "Segoe UI", "PingFang SC", "Microsoft YaHei", sans-serif;
      color: var(--text);
      background:
        radial-gradient(circle at top left, rgba(103, 232, 249, 0.12), transparent 24%),
        linear-gradient(180deg, #07101d, #0a1322 42%, #08111f);
    }
    button, input { font: inherit; }
    button { cursor: pointer; }
    .app {
      min-height: 100vh;
      display: grid;
      grid-template-columns: 272px minmax(0, 1fr);
      max-width: 1800px;
      margin: 0 auto;
    }
    .sidebar {
      position: sticky;
      top: 0;
      height: 100vh;
      padding: 24px 18px;
      border-right: 1px solid var(--line);
      background: linear-gradient(180deg, rgba(7, 15, 27, 0.96), rgba(8, 17, 31, 0.94));
      display: grid;
      grid-template-rows: auto auto 1fr;
      gap: 20px;
    }
    .brand { display: grid; gap: 8px; }
    .eyebrow {
      font-size: 12px;
      letter-spacing: .18em;
      text-transform: uppercase;
      color: var(--accent-2);
    }
    .brand h1, .topbar h2, .section-title { margin: 0; letter-spacing: -.03em; }
    .brand h1 { font-size: 30px; line-height: 1.05; }
    .brand p, .topbar p, .muted, .empty { margin: 0; color: var(--muted); line-height: 1.55; }
    .nav { display: grid; gap: 10px; }
    .nav-btn {
      width: 100%;
      text-align: left;
      padding: 14px 15px;
      border-radius: 14px;
      background: transparent;
      color: var(--text);
      border: 1px solid transparent;
      display: grid;
      gap: 4px;
      transition: .15s ease;
    }
    .nav-btn:hover, .nav-btn.active {
      background: rgba(94, 234, 212, 0.08);
      border-color: rgba(94, 234, 212, 0.16);
      transform: translateX(2px);
    }
    .nav-btn strong { font-size: 15px; }
    .nav-btn span { color: var(--muted); font-size: 12px; }
    .side-panel, .panel, .hero, .metric, .notice {
      background: linear-gradient(180deg, var(--panel), rgba(8, 18, 34, 0.76));
      border: 1px solid var(--line);
      border-radius: var(--radius);
      box-shadow: var(--shadow);
    }
    .side-panel, .panel, .notice { padding: 18px; }
    .side-panel { align-self: end; display: grid; gap: 10px; }
    .workspace { padding: 24px 28px 36px; }
    .workspace-inner { max-width: 1480px; margin: 0 auto; display: grid; gap: 18px; }
    .topbar {
      display: grid;
      grid-template-columns: minmax(0, 1fr) auto;
      gap: 16px;
      align-items: start;
    }
    .topbar h2 { font-size: clamp(28px, 3vw, 46px); line-height: 1.02; margin-top: 4px; margin-bottom: 8px; }
    .top-actions { display: grid; gap: 10px; justify-items: end; min-width: 320px; }
    .status-row, .btn-row, .meta-row, .tiles, .two, .three { display: grid; gap: 14px; }
    .status-row { display: flex; justify-content: flex-end; align-items: center; gap: 10px; flex-wrap: wrap; }
    .btn-row { display: flex; justify-content: flex-end; gap: 10px; flex-wrap: wrap; }
    .status-pill {
      display: inline-flex;
      gap: 8px;
      align-items: center;
      padding: 10px 14px;
      border-radius: 999px;
      background: rgba(15, 33, 57, 0.82);
      border: 1px solid var(--line);
      font-weight: 700;
    }
    .status-pill::before {
      content: "";
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: var(--muted);
      box-shadow: 0 0 0 6px rgba(148, 163, 184, 0.12);
    }
    .status-pill[data-status="running"]::before,
    .status-pill[data-status="loading"]::before {
      background: var(--accent-2);
      box-shadow: 0 0 0 6px rgba(94, 234, 212, 0.14);
    }
    .status-pill[data-status="error"]::before {
      background: var(--bad);
      box-shadow: 0 0 0 6px rgba(251, 113, 133, 0.14);
    }
    .status-pill[data-status="success"]::before {
      background: var(--good);
      box-shadow: 0 0 0 6px rgba(74, 222, 128, 0.14);
    }
    .status-line { color: var(--muted); font-size: 13px; }
    .btn {
      min-height: 44px;
      border-radius: 999px;
      border: 1px solid var(--line);
      padding: 0 16px;
      font-weight: 700;
      color: var(--text);
      background: rgba(15, 33, 57, 0.88);
    }
    .btn.primary {
      color: #041118;
      border: 0;
      background: linear-gradient(135deg, var(--accent-2), var(--accent));
    }
    .notice { display: grid; gap: 8px; }
    .notice[data-tone="error"] { border-color: rgba(251, 113, 133, 0.3); }
    .notice[data-tone="warning"] { border-color: rgba(251, 191, 36, 0.28); }
    .view { display: grid; gap: 18px; animation: fade .16s ease; }
    @keyframes fade { from { opacity: 0; transform: translateY(6px); } to { opacity: 1; transform: translateY(0); } }
    .hero { padding: 24px; display: grid; gap: 18px; position: relative; overflow: hidden; }
    .hero::after {
      content: "";
      position: absolute;
      right: -60px;
      bottom: -60px;
      width: 240px;
      height: 240px;
      background: radial-gradient(circle, rgba(103, 232, 249, 0.18), transparent 62%);
    }
    .hero h3 { margin: 0; font-size: 24px; }
    .hero-value { display: flex; gap: 16px; align-items: baseline; flex-wrap: wrap; position: relative; z-index: 1; }
    .hero-number { font-size: clamp(42px, 5vw, 80px); line-height: .95; letter-spacing: -.06em; font-weight: 800; }
    .hero-badge {
      padding: 8px 14px;
      border-radius: 999px;
      border: 1px solid rgba(255,255,255,.08);
      background: rgba(255,255,255,.05);
      font-weight: 700;
    }
    .meta-row { display: flex; flex-wrap: wrap; }
    .meta-chip {
      min-width: 132px;
      padding: 10px 12px;
      border-radius: 14px;
      background: rgba(255, 255, 255, 0.04);
      border: 1px solid rgba(255,255,255,.05);
    }
    .meta-chip span, .kv span, .table th { color: var(--muted); font-size: 12px; }
    .meta-chip strong, .kv strong { display: block; margin-top: 6px; font-size: 18px; }
    .tiles { grid-template-columns: repeat(auto-fit, minmax(160px, 1fr)); }
    .metric { padding: 18px; }
    .metric strong { display: block; margin: 6px 0; font-size: clamp(24px, 2.2vw, 38px); line-height: 1; letter-spacing: -.04em; }
    .two { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    .three { grid-template-columns: 1.2fr .8fr; }
    .panel { display: grid; gap: 14px; }
    .section-head { display: flex; justify-content: space-between; gap: 10px; align-items: end; flex-wrap: wrap; }
    .section-title { font-size: 22px; line-height: 1.06; }
    .tag {
      display: inline-flex;
      padding: 6px 10px;
      border-radius: 999px;
      background: rgba(94, 234, 212, 0.08);
      border: 1px solid rgba(94, 234, 212, 0.14);
      color: var(--accent-2);
      font-size: 12px;
      font-weight: 700;
    }
    .kv-list { display: grid; gap: 10px; }
    .kv {
      display: grid;
      grid-template-columns: minmax(120px, .9fr) 1fr;
      gap: 12px;
      padding-bottom: 10px;
      border-bottom: 1px solid rgba(255,255,255,.05);
    }
    .kv:last-child { border-bottom: 0; padding-bottom: 0; }
    .chart {
      border: 1px solid var(--line);
      border-radius: 16px;
      padding: 12px;
      background: linear-gradient(180deg, rgba(7, 16, 29, 0.88), rgba(7, 16, 29, 0.64));
    }
    .alerts { display: grid; gap: 12px; }
    .alert {
      padding: 14px;
      border-radius: 14px;
      border: 1px solid rgba(255,255,255,.06);
      background: rgba(255,255,255,.03);
      display: grid;
      gap: 6px;
    }
    .severity { display: inline-flex; padding: 4px 10px; border-radius: 999px; font-size: 12px; font-weight: 700; }
    .severity.info { color: var(--accent-2); background: rgba(94, 234, 212, 0.08); }
    .severity.warning { color: var(--warn); background: rgba(251, 191, 36, 0.08); }
    .severity.critical { color: var(--bad); background: rgba(251, 113, 133, 0.08); }
    .table-wrap { overflow: auto; border: 1px solid var(--line); border-radius: 16px; }
    .table { width: 100%; border-collapse: collapse; min-width: 680px; }
    .table th, .table td {
      padding: 13px 14px;
      text-align: left;
      border-bottom: 1px solid rgba(255,255,255,.05);
      white-space: nowrap;
      vertical-align: top;
      font-size: 14px;
    }
    .table th {
      position: sticky;
      top: 0;
      background: rgba(8, 16, 30, 0.98);
      text-transform: uppercase;
      letter-spacing: .08em;
    }
    .table tr:last-child td { border-bottom: 0; }
    .field-grid { display: grid; gap: 14px; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); }
    .field { display: grid; gap: 8px; }
    .field label, .field span { font-size: 13px; color: var(--muted); }
    .field input[type="number"] {
      min-height: 46px;
      border-radius: 14px;
      border: 1px solid rgba(143, 180, 235, 0.22);
      background: rgba(5, 12, 23, 0.86);
      color: var(--text);
      padding: 0 14px;
    }
    .agent-list { border: 1px solid var(--line); border-radius: 16px; overflow: hidden; }
    .agent-row {
      display: grid;
      grid-template-columns: minmax(180px, 1fr) 120px minmax(150px, 220px);
      gap: 16px;
      align-items: center;
      padding: 16px;
      border-bottom: 1px solid rgba(255,255,255,.05);
      background: rgba(255,255,255,.02);
    }
    .agent-row:last-child { border-bottom: 0; }
    .check { display: inline-flex; align-items: center; gap: 10px; }
    .good { color: var(--good); }
    .bad { color: var(--bad); }
    @media (max-width: 1200px) {
      .app { grid-template-columns: 1fr; }
      .sidebar {
        position: static;
        height: auto;
        border-right: 0;
        border-bottom: 1px solid var(--line);
      }
    }
    @media (max-width: 960px) {
      .workspace { padding: 18px 14px 24px; }
      .topbar, .two, .three { grid-template-columns: 1fr; }
      .top-actions { justify-items: stretch; min-width: 0; }
      .status-row, .btn-row { justify-content: flex-start; }
      .agent-row { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>
  <div class="app">
    <aside class="sidebar">
      <div class="brand">
        <div class="eyebrow">Multi-Agent Quant</div>
        <h1>量化控制台</h1>
        <p>拆成清晰模块页，让用户先判断、再操作、最后追踪历史，而不是被一整页混杂信息淹没。</p>
      </div>
      <nav id="nav" class="nav"></nav>
      <section id="sidebarPanel" class="side-panel"></section>
    </aside>

    <section class="workspace">
      <div class="workspace-inner">
        <header class="topbar">
          <div>
            <div id="routeEyebrow" class="eyebrow"></div>
            <h2 id="routeTitle"></h2>
            <p id="routeSubtitle"></p>
          </div>
          <div class="top-actions">
            <div class="status-row">
              <div id="statusBadge" class="status-pill" data-status="idle">待机</div>
              <div id="statusLine" class="status-line"></div>
            </div>
            <div class="btn-row">
              <button class="btn" data-action="refresh">刷新状态</button>
              <button class="btn" data-action="disable-loser">禁用最弱智能体</button>
              <button id="runButton" class="btn primary" data-action="run">运行模拟</button>
            </div>
          </div>
        </header>

        <section id="notice" class="notice"></section>
        <main id="view"></main>
      </div>
    </section>
  </div>

  <script>
    const ROUTES = {
      overview: { label: "总览", brief: "先看当前是否健康", eyebrow: "Workspace / Overview", title: "一眼看清系统现在赚没赚钱、稳不稳定", subtitle: "总览页只放最关键的结果：权益、收益、风险告警和最近成交。" },
      run: { label: "运行", brief: "集中改参数和启动", eyebrow: "Workspace / Run", title: "把启动、风控和智能体开关收拢到一个页面", subtitle: "运行页只负责配置与启动，不再混进持仓和实验历史。" },
      agents: { label: "智能体", brief: "只看 agent 表现", eyebrow: "Workspace / Agents", title: "单独追踪每个智能体的贡献与 NAV 曲线", subtitle: "这里不放持仓细表，只看谁赚钱、谁拖后腿、曲线是否稳定。" },
      portfolio: { label: "持仓", brief: "专门看账本和盈亏", eyebrow: "Workspace / Portfolio", title: "把持仓、盈亏和成交流水集中到同一条资金视角", subtitle: "持仓页就是账本页，不再被参数、历史和实验结果打断。" },
      history: { label: "历史", brief: "看对比和实验结果", eyebrow: "Workspace / History", title: "历史、对比和 ablation 单独归档", subtitle: "纵向追踪放到一页里看，避免和当前实时状态混在一起。" }
    };

    const nav = document.getElementById("nav");
    const sidebarPanel = document.getElementById("sidebarPanel");
    const routeEyebrow = document.getElementById("routeEyebrow");
    const routeTitle = document.getElementById("routeTitle");
    const routeSubtitle = document.getElementById("routeSubtitle");
    const statusBadge = document.getElementById("statusBadge");
    const statusLine = document.getElementById("statusLine");
    const notice = document.getElementById("notice");
    const view = document.getElementById("view");
    const runButton = document.getElementById("runButton");

    const POLL_MS = 1500;
    let currentState = null;
    let controlDraft = null;
    let draftDirty = false;
    let fetchInFlight = false;
    let poller = null;

    function routePath(route) {
      return `/console/${route}`;
    }

    function getRoute() {
      const path = window.location.pathname.replace(/\/+$/, "");
      const last = path.split("/").filter(Boolean).pop() || "";
      return ROUTES[last] ? last : "overview";
    }

    function ensureRoute() {
      const route = getRoute();
      const expected = routePath(route);
      if (window.location.pathname !== expected) {
        history.replaceState({}, "", expected);
      }
      return route;
    }

    function navigate(route) {
      const next = ROUTES[route] ? route : "overview";
      const path = routePath(next);
      if (window.location.pathname !== path) {
        history.pushState({}, "", path);
      }
      render(currentState);
    }

    function cloneControls(controls) {
      const source = controls || {};
      const risk = source.risk_controls || {};
      return {
        loop_iterations: Number(source.loop_iterations || 80),
        risk_controls: {
          max_stock_position_pct: Number(risk.max_stock_position_pct ?? 0.3),
          max_futures_contracts_per_symbol: Number(risk.max_futures_contracts_per_symbol ?? 2),
          max_futures_margin_pct: Number(risk.max_futures_margin_pct ?? 0.28),
          max_futures_notional_pct: Number(risk.max_futures_notional_pct ?? 0.7),
          max_gross_exposure_pct: Number(risk.max_gross_exposure_pct ?? 0.95)
        },
        agents: (source.agents || []).map((agent) => ({
          id: agent.id,
          role: agent.role,
          enabled: Boolean(agent.enabled),
          capital_ratio: Number(agent.capital_ratio ?? 0)
        }))
      };
    }

    function syncDraft(controls, force = false) {
      if (!controlDraft || force || !draftDirty) {
        controlDraft = cloneControls(controls);
      }
    }

    async function fetchState() {
      if (fetchInFlight) return;
      fetchInFlight = true;
      const response = await fetch("/api/state");
      try {
        const payload = await response.json();
        currentState = payload;
        syncDraft(payload.controls || {});
        render(payload);
      } finally {
        fetchInFlight = false;
      }
    }

    function startPolling() {
      if (poller !== null) return;
      poller = window.setInterval(() => {
        fetchState().catch((error) => setErrorStatus(error.message));
      }, POLL_MS);
    }

    function setErrorStatus(message) {
      statusBadge.dataset.status = "error";
      statusBadge.textContent = "异常";
      statusLine.textContent = message;
    }

    function render(state) {
      const route = ensureRoute();
      renderNav(route);
      renderHeader(route, state);
      renderSidebar(state);
      renderNotice(state);
      view.innerHTML = renderRoute(route, state);
      updateRunButton(state?.status || "idle");
    }

    function renderNav(route) {
      nav.innerHTML = Object.entries(ROUTES).map(([key, meta]) => `
        <button class="nav-btn ${key === route ? "active" : ""}" type="button" data-route="${key}">
          <strong>${meta.label}</strong>
          <span>${meta.brief}</span>
        </button>
      `).join("");
    }

    function renderHeader(route, state) {
      const meta = ROUTES[route];
      routeEyebrow.textContent = meta.eyebrow;
      routeTitle.textContent = meta.title;
      routeSubtitle.textContent = meta.subtitle;
      const status = state?.status || "idle";
      statusBadge.dataset.status = status;
      statusBadge.textContent = translateStatus(status);
      statusLine.textContent = state?.summary?.generated_at
        ? `最新结果 ${formatDateTime(state.summary.generated_at)}`
        : "等待运行结果";
    }

    function renderSidebar(state) {
      const kpis = state?.summary?.kpis || {};
      const comparison = state?.comparison || null;
      sidebarPanel.innerHTML = `
        <div class="eyebrow">Quick Look</div>
        <div class="kv-list">
          ${kv("总权益", formatValue(kpis.equity))}
          ${kv("已实现盈亏", formatSigned(kpis.realized_pnl))}
          ${kv("未实现盈亏", formatSigned(kpis.unrealized_pnl_total ?? kpis.futures_unrealized_pnl))}
          ${kv("成交笔数", formatValue(kpis.trade_count))}
          ${kv("相较上次", comparison ? `${formatSigned(comparison.return_pct_delta)}%` : "-")}
        </div>
        <p class="muted">每个路由只处理一种任务，避免用户在长页中自己找功能模块。</p>
      `;
    }

    function renderNotice(state) {
      const hasError = Boolean(state?.last_error);
      const tone = hasError ? "error" : (state?.status === "running" || state?.status === "loading") ? "warning" : "normal";
      const summary = state?.summary || null;
      notice.dataset.tone = tone;
      notice.innerHTML = hasError
        ? `<strong>最近一次运行出现异常</strong><div class="muted">${escapeHtml(state.last_error)}</div>`
        : `<strong>当前上下文</strong><div class="meta-row">
            <div class="meta-chip"><span>模式</span><strong>${escapeHtml(translateMode(summary?.mode))}</strong></div>
            <div class="meta-chip"><span>市场</span><strong>${escapeHtml(translateMarket(summary?.market))}</strong></div>
            <div class="meta-chip"><span>配置</span><strong>${escapeHtml(state?.active_config_path || state?.config_path || "-")}</strong></div>
          </div>`;
    }

    function renderRoute(route, state) {
      if (route === "run") return renderRun(state);
      if (route === "agents") return renderAgents(state?.summary || null);
      if (route === "portfolio") return renderPortfolio(state?.summary || null);
      if (route === "history") return renderHistory(state);
      return renderOverview(state);
    }

    function renderOverview(state) {
      const summary = state?.summary;
      if (!summary) return empty("还没有运行结果", "先到“运行”页启动一次模拟，这里就会出现权益、风险和最新成交。");
      const kpis = summary.kpis || {};
      const perf = summary.performance || {};
      const holdings = [...(summary.positions?.stocks || [])].sort((a, b) => Number(b.market_value || 0) - Number(a.market_value || 0)).slice(0, 5);
      const fills = (summary.recent_fills || []).slice(0, 8);
      return `<div class="view">
        <div class="three">
          <section class="hero">
            <div>
              <div class="eyebrow">Capital Snapshot</div>
              <h3>当前组合权益</h3>
              <p class="muted">总览页只回答三个问题：有没有赚钱、风险是否可控、系统最近有没有异常。</p>
            </div>
            <div class="hero-value">
              <div class="hero-number">${formatValue(kpis.equity)}</div>
              <div class="hero-badge ${toneClass(formatSigned(perf.total_return_pct))}">${formatSigned(perf.total_return_pct)}%</div>
            </div>
            <div class="meta-row">
              ${meta("可用现金", formatValue(kpis.cash_available))}
              ${meta("总敞口", formatValue(kpis.gross_exposure))}
              ${meta("最大回撤", `${formatValue(perf.max_drawdown_pct)}%`)}
              ${meta("成交笔数", formatValue(kpis.trade_count))}
            </div>
          </section>
          <section class="panel">
            <div class="section-head"><div class="tag">立即判断</div></div>
            <div class="kv-list">
              ${kv("已实现盈亏", formatSigned(kpis.realized_pnl))}
              ${kv("未实现盈亏", formatSigned(kpis.unrealized_pnl_total ?? kpis.futures_unrealized_pnl))}
              ${kv("股票市值", formatValue(kpis.stock_market_value))}
              ${kv("杠杆率", formatValue(kpis.leverage_ratio))}
              ${kv("市场模式", `${translateMarket(summary.market)} / ${translateMode(summary.mode)}`)}
            </div>
          </section>
        </div>
        <section class="tiles">
          ${metric("期货保证金", formatValue(kpis.futures_margin_in_use), "当前保证金占用")}
          ${metric("总费用", formatValue(kpis.total_fees), "累计执行成本")}
          ${metric("波动率", `${formatValue(perf.volatility_pct)}%`, "收益波动强度")}
